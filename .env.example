# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
FRONTEND_URL="http://localhost:3000"

# Database (Neon)
# Use pooled URL for runtime queries
DATABASE_URL="postgresql://<user>:<password>@<host>/<dbname>?sslmode=require"
# Use direct URL for migrations
DIRECT_URL="postgresql://<user>:<password>@<host>/<dbname>?sslmode=require"

# Auth
BETTER_AUTH_SECRET="replace-with-long-random-secret"

# Stripe
# Required for payment link creation and webhook signature verification
STRIPE_SECRET_KEY="sk_test_or_live_key_here"
STRIPE_WEBHOOK_SECRET="whsec_from_stripe_dashboard"
# Optional: needed only if you use client-side Stripe.js widgets directly
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=""

# Optional admin bootstrap for db:seed
ADMIN_FULL_NAME="SkyBook Administrator"
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# AviationStack reference data (hybrid approach)
AVIATIONSTACK_API_KEY="replace-with-aviationstack-api-key"
AVIATIONSTACK_BASE_URL="https://api.aviationstack.com/v1"

# External API (optional legacy provider)
AMADEUS_API_KEY=""
AMADEUS_API_SECRET=""
